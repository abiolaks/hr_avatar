# =============================================================================
# HR Avatar — Environment Variables
# Copy this file to .env and fill in your values.
#   cp .env.example .env
# =============================================================================

# ── LMS Integration ───────────────────────────────────────────────────────────
# Shared secret between the LMS backend and the Avatar API.
# The LMS sends this as: Authorization: Bearer <secret>
LMS_SHARED_SECRET=change-me-in-production

# ── Ollama ────────────────────────────────────────────────────────────────────
# Base URL for the Ollama service.
# Local dev: http://localhost:11434
# Docker Compose: http://ollama:11434  (set automatically in docker-compose.yml)
OLLAMA_BASE_URL=http://localhost:11434

# ── Recommendation / Assessment APIs ─────────────────────────────────────────
# Defaults to the mock server (mock_services.py) running on port 8001.
# Replace with your real LMS API URLs in production.
RECOMMENDATION_API_URL=http://localhost:8001/recommend
ASSESSMENT_API_URL=http://localhost:8001/generate

# ── Azure Blob Storage (optional) ────────────────────────────────────────────
# Leave blank to use local hr_docs/ only.
# Set both to enable ingesting documents from Azure Blob Storage.
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=hr-documents

# ── Logging ───────────────────────────────────────────────────────────────────
# DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
